# Basis-Image für App- und Frontend-Dev-Container: pnpm ist bereits aktiviert.
# Beim Start laufen die Services mit user ${UID}:${GID}, sodass node_modules dir gehören.
FROM node:24-alpine
ARG TYPST_VERSION=0.13.1
COPY docker/install-typst-alpine.sh /tmp/install-typst-alpine.sh
RUN apk add --no-cache wget pandoc postgresql-client zstd tar xz \
  && TYPST_VERSION="${TYPST_VERSION}" sh /tmp/install-typst-alpine.sh \
  && rm /tmp/install-typst-alpine.sh \
  && corepack enable pnpm
ENV PANDOC_ARGS=--pdf-engine=typst

# PNPM Home Verzeichnis definieren und PATH erweitern
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

# Verzeichnis erstellen, damit der spätere User darin schreiben darf
RUN mkdir -p /pnpm && chmod 777 /pnpm